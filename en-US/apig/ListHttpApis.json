      "position": "Query",
      "type": "String",
      "required": false
    },
    {
      "name": "gatewayType",
      "description": "The API information.",
      "position": "Query",
      "type": "String",
      "required": false
    },
    {
      "name": "keyword",
      "description": "The consumer authentication policy in the specified environment in each returned API.",
      "position": "Query",
      "type": "String",
      "required": false
    },
    {
      "name": "name",
      "description": "Specifies whether authentication is enabled.",
      "position": "Query",
      "type": "String",
      "required": false
    },
    {
      "name": "pageNumber",
      "description": "The environment information.",
      "position": "Query",
      "type": "Integer",
      "required": false
    },
    {
      "name": "pageSize",
      "description": "The resource group ID.",
      "position": "Query",
      "type": "Integer",
      "required": false
    },
    {
      "name": "resourceGroupId",
